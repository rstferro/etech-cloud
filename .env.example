# Copie para .env e ajuste os valores.

# Banco de dados (Prisma + adapter libSQL)
# Dev local com SQLite (arquivo):
DATABASE_URL="file:./dev.db"

# Produção com Turso/libSQL — troque a URL e informe o token:
#   turso db show SEU-BANCO --url     -> pega a URL libsql://
#   turso db tokens create SEU-BANCO  -> gera o auth token
# DATABASE_URL="libsql://SEU-BANCO.turso.io"
TURSO_AUTH_TOKEN=""

# Auth.js (NextAuth v5)
# Gere com: npx auth secret  (ou node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_TRUST_HOST=true

# IA — sugestão de laudo técnico com Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=""
# Modelo (opcional). Barato/rápido: claude-haiku-4-5 · Mais capaz: claude-opus-4-8
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
# Modo demonstração: "true" gera o laudo localmente, sem chamar a API (custo zero).
# Deixe "true" pro deploy de portfólio não gastar créditos; use a IA real localmente.
LAUDO_DEMO="true"
